{
    "name": "psc-acme/validator-auth",
    "description": "Package validator-auth for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ValidatorAuth\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "symfony/string": "^7.0",
        "league/csv": "^9.0",
        "monolog/monolog": "^3.2.0",
        "illuminate/database": "^11.0",
        "brick/math": "^0.12",
        "league/flysystem": "^3.0"
    },
    "require-dev": {
        "symfony/phpunit-bridge": "^7.0",
        "behat/behat": "^3.14"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}